# --- Telegram ---
# BotFather bergan tokenni shu yerga emas, deploy platformasi (Render) env'iga yozing.
BOT_TOKEN=BU_YERGA_BOT_TOKEN
# Kanal: ommaviy bo'lsa @username, yopiq bo'lsa raqamli -100xxxxxxxxxx
CHANNEL_ID=@sahovatshifo_kanal
CHANNEL_TITLE=Sahovat Shifo
# Bot ichidagi adminlar (Telegram user ID, vergul bilan)
ADMIN_IDS=

# --- Web / deploy ---
# Deploydan keyin platforma bergan URL, masalan https://saxovat-bot.onrender.com
WEBHOOK_BASE_URL=
# URL maxfiy qismi (uzun tasodifiy satr qo'ying)
WEBHOOK_SECRET=almashtiring-uzun-tasodifiy-satr
# webhook (deploy) yoki polling (lokal test)
RUN_MODE=webhook

# --- Admin panel ---
ADMIN_PASSWORD=almashtiring-kuchli-parol
SESSION_SECRET=almashtiring-uzun-tasodifiy-satr-2

# --- Baza ---
# Lokal: SQLite. Deployда Postgres: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data.db
